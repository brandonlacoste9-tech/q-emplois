# QWORKS Backend Environment Configuration

# ============================================
# Database (Supabase: Session pooler URI from dashboard — port 5432)
# Migration already on Supabase; DIRECT_URL not required.
# ============================================
DATABASE_URL=postgresql://postgres.masefoylqhqfijszezla:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Redis (optional — omit on Railway to use in-memory fallback)
# Upstash: redis://default:password@host:6379
# ============================================
# REDIS_URL=

# ============================================
# Stripe Payments
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============================================
# Twilio WhatsApp
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option A: primary auth token
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B: API key (recommended for production)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ============================================
# API Configuration
# ============================================
PORT=3000
API_KEY=your-api-key-for-internal-communication
CORS_ORIGIN=http://localhost:5173

# ============================================
# Frontend URL (for email links, redirects)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@qworks.ca

# ============================================
# Law 25 / Privacy Compliance
# ============================================
DATA_RETENTION_DAYS=30
PRIVACY_POLICY_URL=https://qworks.ca/politique-confidentialite
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
