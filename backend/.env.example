# Q-Emplois Backend — Environment Configuration
# Copy to .env and fill in your values.

# ============================================
# Database (Supabase — use session pooler URI)
# ============================================
DATABASE_URL=postgresql://postgres.YOUR_REF:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Redis (optional — in-memory fallback if not set)
# Upstash: redis://default:password@host:6379
# ============================================
# REDIS_URL=

# ============================================
# Stripe Payments
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============================================
# Telegram Bot
# Get token from @BotFather, username is the @handle without @
# ============================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=QEmploisBot

# ============================================
# API / App
# ============================================
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Production:
# FRONTEND_URL=https://q-emplois.vercel.app

# Backend URL (used by register-telegram-webhook.ts script)
BACKEND_URL=https://api.qemplois.ca

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@q-emplois.ca
ADMIN_EMAIL=admin@q-emplois.ca

# ============================================
# Storage (for license documents & avatars)
# ============================================
# STORAGE_BUCKET=q-emplois-uploads
# STORAGE_ENDPOINT=https://xxx.supabase.co/storage/v1

# ============================================
# Law 25 / Privacy
# ============================================
DATA_RETENTION_DAYS=2555
PRIVACY_POLICY_URL=https://q-emplois.ca/politique-confidentialite
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# Webhooks (auth-callback controller)
# ============================================
WEBHOOK_URL=https://api.qemplois.ca/api/webhooks/auth
WEBHOOK_SECRET=your-webhook-secret

# ============================================
# Sentry (optional error monitoring)
# ============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# Demo jobs rotation (cron — production defaults shown)
# ============================================
DEMO_JOBS_CRON_ENABLED=true
DEMO_JOBS_ROTATION_DAYS=3
DEMO_JOBS_MIN_OPEN=6

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
