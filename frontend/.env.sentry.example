# Sentry Configuration (Frontend Error Tracking)
#
# 1. Create a project at https://sentry.io
# 2. Get your DSN from Project Settings → Client Keys (DSN)
# 3. For source maps (optional but recommended), create an Auth Token
#    with "project:releases" and "project:write" scopes.

VITE_SENTRY_DSN=https://your-key@o12345.ingest.sentry.io/1234567
SENTRY_ORG=your-org
SENTRY_PROJECT=q-emplois
SENTRY_AUTH_TOKEN=sntrys_...
